generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  walletAddress String   @unique
  role          String   @default("SELLER") // BUYER, SELLER, BOTH
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  budget         Float
  buyerAddress   String
  sellerAddress  String?
  txHash         String?
  status         String   @default("CREATED") // CREATED, ACTIVE, IN_REVIEW, DISPUTED, RESOLVED, COMPLETED
  rejectionCount Int      @default(0)
  rejectionFeedback String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Off-chain evidence details
  githubUrl      String?
  demoUrl        String?
  evidenceNotes  String?
}

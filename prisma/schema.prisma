generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  budget         Float
  buyerAddress   String
  sellerAddress  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Off-chain evidence details
  githubUrl      String?
  demoUrl        String?
  evidenceNotes  String?

  // State replication (for UI convenience, source of truth is on-chain)
  status         String   @default("CREATED") // CREATED, ACTIVE, IN_REVIEW, DISPUTED, RESOLVED, COMPLETED
}
